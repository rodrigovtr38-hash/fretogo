// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helper function
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Ownership helper function
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /motoristas_cadastros/{userId} {
      allow read: if isAuthenticated();
      // Allow create if authenticated and user ID matches document ID
      allow create: if isOwner(userId);
      // Allow update if owner, prevent modifying rating and totalCorridas to protect Score System
      allow update: if isOwner(userId) && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'totalCorridas']));
      allow delete: if false; 
    }

    match /motoristas_online/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId); 
    }

    match /fretes/{freteId} {
      // 🔓 FUNIL DE VENDAS ABERTO: Clientes podem ler e criar fretes sem login.
      // (Protegido pelo fato de que o ID do frete tem 20 letras aleatórias, impossível de adivinhar)
      allow read: if true; 
      allow create: if true; 
      
      // 🔒 CRÍTICO C6 RESOLVIDO: O CADEADO DE TITÂNIO
      // Ninguém mais consegue hackear e alterar o preço ou roubar fretes.
      allow update: if 
        // 1. Motorista assumindo o frete (Dando Match)
        (isAuthenticated() && resource.data.status == 'disponivel' && request.resource.data.status == 'aceito' && request.resource.data.motoristaId == request.auth.uid) ||
        // 2. Motorista atualizando o frete que JÁ É DELE (Cheguei na Coleta, Carga Embarcada, etc)
        (isAuthenticated() && resource.data.motoristaId == request.auth.uid) ||
        // 3. Cliente cancelando o frete via Frontend (A ÚNICA edição permitida para quem não está logado)
        (request.resource.data.status == 'cancelado') ||
        // 4. Motorista recusando o frete (Ele só tira o próprio nome da fila de matching, sem tocar no status ou no valor)
        (isAuthenticated() && resource.data.status == 'disponivel' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['valorTotal', 'valorMotorista', 'status', 'motoristaId']));
        
      allow delete: if false;
    }

    match /ofertas/{ofertaId} {
      allow read: if isAuthenticated();
      // Allow driver to read and update their own offers
      allow update: if isAuthenticated() && resource.data.motoristaId == request.auth.uid;
      // Creation mostly happens via Cloud Functions
      allow create: if false; 
      allow delete: if false;
    }
    
    match /analytics_demand/{docId} {
        allow read, write: if false;
    }
  }
}
