rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // =========================================================
    // 🔐 HELPERS
    // =========================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId;
    }

    // 🔥 ADMINS OFICIAIS
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.uid in [
          "SEU_UID_ADMIN_AQUI"
        ];
    }

    // =========================================================
    // 🚚 MOTORISTAS CADASTROS
    // =========================================================

    match /motoristas_cadastros/{userId} {

      allow read: if isAuthenticated();

      allow create: if isOwner(userId);

      allow update: if

        // 👤 Dono atualizando perfil limitado
        (
          isOwner(userId) &&

          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              'score',
              'taxaAceite',
              'totalCorridas',
              'aprovado',
              'status',
              'riscoFraude',
              'validacaoManual'
            ])
        )

        ||

        // 🛡️ Admin validando motorista
        isAdmin();

      allow delete: if false;
    }

    // =========================================================
    // 📡 MOTORISTAS ONLINE
    // =========================================================

    match /motoristas_online/{userId} {

      allow read: if isAuthenticated();

      allow create, update: if

        isOwner(userId)

        &&

        request.resource.data.keys().hasAll([
          'lat',
          'lng',
          'status'
        ]);

      allow delete: if
        isOwner(userId)
        || isAdmin();
    }

    // =========================================================
    // 📦 FRETES
    // =========================================================

    match /fretes/{freteId} {

      // 🔒 Apenas usuários autenticados leem
      allow read: if isAuthenticated();

      // 🟢 Cliente cria frete
      allow create: if

        request.resource.data.keys().hasAll([
          'status',
          'valorTotal',
          'cidadeOrigem',
          'cidadeDestino',
          'createdAt'
        ]);

      // =====================================================
      // 🔄 UPDATE
      // =====================================================

      allow update: if

        // =================================================
        // 🚚 MOTORISTA ACEITANDO FRETE
        // =================================================

        (
          isAuthenticated()

          &&

          resource.data.status == 'disponivel'

          &&

          request.resource.data.status == 'aceito'

          &&

          request.resource.data.motoristaId == request.auth.uid
        )

        ||

        // =================================================
        // 🚚 MOTORISTA ATUALIZANDO PRÓPRIO FRETE
        // =================================================

        (
          isAuthenticated()

          &&

          resource.data.motoristaId == request.auth.uid

          &&

          !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              'valorTotal',
              'valorMotorista',
              'lucroPlataforma',
              'clienteNome',
              'clienteZap'
            ])
        )

        ||

        // =================================================
        // 🛡️ ADMIN TOTAL
        // =================================================

        isAdmin();

      allow delete: if false;
    }

    // =========================================================
    // 🎯 OFERTAS
    // =========================================================

    match /ofertas/{ofertaId} {

      allow read: if isAuthenticated();

      allow update: if

        isAuthenticated()

        &&

        resource.data.motoristaId == request.auth.uid;

      allow create: if false;

      allow delete: if false;
    }

    // =========================================================
    // 📊 ANALYTICS
    // =========================================================

    match /analytics_demand/{docId} {

      allow read: if isAdmin();

      allow write: if false;
    }

    // =========================================================
    // 🛡️ FALLBACK GLOBAL
    // =========================================================

    match /{document=**} {

      allow read, write: if false;
    }
  }
}
