rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 🔐 HELPERS E SEGURANÇA MESTRE
    // =========================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 🔥 SUA CHAVE MESTRA INJETADA
    function isAdmin() {
      return isAuthenticated() && request.auth.uid in [
        "uV1yeZoGfhZTRWDVL1CnMW6b6NY2"
      ];
    }

    // =========================================================
    // 🚚 MOTORISTAS CADASTROS (APROVAÇÃO)
    // =========================================================

    match /motoristas_cadastros/{userId} {
      // CORREÇÃO CRÍTICA (LGPD): Motorista só lê o próprio cadastro. Admin lê tudo.
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'score', 'taxaAceite', 'totalCorridas', 'aprovado', 'status', 'riscoFraude', 'validacaoManual'
        ])) 
        || isAdmin();
      allow delete: if false;
    }

    // =========================================================
    // 📡 MOTORISTAS ONLINE (RADAR)
    // =========================================================

    match /motoristas_online/{userId} {
      allow read: if isAuthenticated();
      // CORREÇÃO CRÍTICA (RADAR): Removida exigência de lat/lng/status que quebrava o app
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // =========================================================
    // 📦 FRETES (BLINDAGEM CONTRA ROUBO DE DADOS E FRAUDE)
    // =========================================================

    match /fretes/{freteId} {
      // CORREÇÃO CRÍTICA (LGPD): Cliente/Motorista só lê o que lhe pertence ou o que está disponível
      allow read: if isAuthenticated() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.motoristaId == request.auth.uid ||
        resource.data.status == 'disponivel' ||
        resource.data.status == 'buscando_motorista' ||
        isAdmin()
      );

      // CORREÇÃO (ANTI-FALSIFICAÇÃO): Exige clienteId na criação
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll([
        'status', 'valorTotal', 'cidadeOrigem', 'cidadeDestino', 'createdAt'
      ]) && request.resource.data.clienteId == request.auth.uid;

      allow update: if
        // 1. Admin Mestre
        isAdmin()
        ||
        // 2. Cliente cancelando o pedido (Apenas altera status e logs de cancelamento)
        (isAuthenticated() && 
         resource.data.clienteId == request.auth.uid &&
         request.resource.data.status == 'cancelado' && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'canceladoEm', 'canceladoPor', 'updatedAt']))
        ||
        // 3. Motorista aceitando frete do radar
        (isAuthenticated() && 
         resource.data.status == 'disponivel' && 
         request.resource.data.status == 'aceito' && 
         request.resource.data.motoristaId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'motoristaId', 'aceitoEm', 'updatedAt']))
        ||
        // 4. Motorista rodando com a carga (NUNCA pode mexer no dinheiro ou no trajeto original)
        (isAuthenticated() && 
         resource.data.motoristaId == request.auth.uid && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'valorTotal', 'valorMotorista', 'valorFreteBruto', 'valorLiquidoMotorista', 
          'lucroPlataforma', 'valorPedagio', 'clienteNome', 'clienteZap', 'clienteId',
          'distancia', 'origemLat', 'origemLng', 'destinoLat', 'destinoLng'
        ]));

      allow delete: if false;
    }

    // =========================================================
    // 🎯 OFERTAS E FILAS
    // =========================================================

    match /ofertas/{ofertaId} {
      allow read: if isAuthenticated() && resource.data.motoristaId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.motoristaId == request.auth.uid;
      allow create, delete: if isAdmin();
    }

    match /analytics_demand/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // =========================================================
    // 🛡 FALLBACK GLOBAL (SE TENTAR INVADIR OUTRA TABELA, BLOQUEIA)
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
